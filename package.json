{
  "name": "playairsoft-monorepo",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"npm run dev:api\" \"npm run dev:web\"",
    "dev:api": "cd apps/api && php artisan serve",
    "dev:web": "npm --prefix apps/web run dev -- --host",
    "install:api": "cd apps/api && composer install",
    "install:web": "npm --prefix apps/web install",
    "setup": "npm run install:web && npm run install:api && cd apps/api && php artisan migrate --seed",
    "build": "npm run build:web",
    "build:web": "npm --prefix apps/web run build",
    "test": "npm run test:api && npm run test:web",
    "test:api": "cd apps/api && php artisan test",
    "test:web": "npm --prefix apps/web run build"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
